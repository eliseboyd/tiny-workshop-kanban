# Copy this file to `.env.local` and fill in values (`.env.local` is gitignored).

# Supabase — from dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: pooler URL; app can derive public Supabase URL from this when NEXT_PUBLIC_* is unset
DATABASE_URL=postgres://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

GOOGLE_AI_API_KEY=your_google_ai_key
POLLINATIONS_API_KEY=your_pollinations_sk_key

# Optional: long random string for POST /api/capture (iOS Shortcuts, scripts). Omit to disable the endpoint.
QUICK_CAPTURE_TOKEN=

# Optional: Bearer token for remote MCP at POST/GET/DELETE /api/mcp (Claude mobile / custom connector).
# If unset, QUICK_CAPTURE_TOKEN is reused when you want one secret for both capture and MCP.
REMOTE_MCP_TOKEN=

